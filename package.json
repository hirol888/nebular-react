{
  "name": "nebular-react",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx serve --port 4300 --open",
    "build": "env BABEL_ENV=build nx run nebular-react:build && nx run nebular-react-playground:build:production",
    "build:lib": "env BABEL_ENV=build nx run nebular-react:build",
    "lint:es": "nx run nebular-react-playground:lint && nx run nebular-react:lint",
    "lint:es:fix": "nx run nebular-react-playground:lint --fix && nx run nebular-react:lint --fix",
    "lint:styles": "stylelint ./libs/nebular-react/src/**/*.scss ./apps/nebular-react-playground/src/**/*.scss --custom-syntax postcss-scss",
    "lint:styles:fix": "stylelint ./libs/nebular-react/src/**/*.scss ./apps/nebular-react-playground/src/**/*.scss --fix --custom-syntax postcss-scss",
    "lint": "npm-run-all -p lint:es lint:styles",
    "lint:fix": "npm-run-all -p lint:es:fix lint:styles:fix",
    "lint:fix:staged": "lint-staged --config ./.lintstagedrc-fix.json",
    "test": "nx run nebular-react:test",
    "test:coverage": "rimraf coverage && nx run nebular-react:test --watchAll=false --coverage --coverageReporters=json",
    "version:bump": "gulp version",
    "prepare": "husky install"
  },
  "private": true,
  "dependencies": {
    "classnames": "^2.3.1",
    "core-js": "^3.6.5",
    "eva-icons": "^1.1.3",
    "inversify": "^6.0.1",
    "inversify-inject-decorators": "^3.1.0",
    "moment": "^2.29.3",
    "observable-hooks": "^4.2.0",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-router-dom": "^6.3.0",
    "react-spring": "^9.4.4",
    "react-use": "^17.3.2",
    "reflect-metadata": "^0.1.13",
    "regenerator-runtime": "0.13.7",
    "rxjs": "^7.5.5",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "@nrwl/cli": "13.10.0",
    "@nrwl/cypress": "13.10.0",
    "@nrwl/eslint-plugin-nx": "13.10.0",
    "@nrwl/jest": "13.10.0",
    "@nrwl/linter": "13.10.0",
    "@nrwl/react": "13.10.0",
    "@nrwl/web": "13.10.0",
    "@nrwl/workspace": "13.10.0",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^12.1.4",
    "@testing-library/react-hooks": "^7.0.2",
    "@types/jest": "27.0.2",
    "@types/lodash": "^4.14.181",
    "@types/node": "16.11.7",
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "~5.18.0",
    "@typescript-eslint/parser": "~5.18.0",
    "babel-jest": "27.2.3",
    "babel-plugin-react-scoped-css": "^1.1.1",
    "cypress": "^9.1.0",
    "eslint": "~8.12.0",
    "eslint-config-prettier": "8.1.0",
    "eslint-plugin-cypress": "^2.10.3",
    "eslint-plugin-import": "2.25.4",
    "eslint-plugin-jsx-a11y": "6.5.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "7.29.4",
    "eslint-plugin-react-hooks": "4.4.0",
    "husky": "^7.0.4",
    "jest": "27.2.3",
    "lint-staged": "^12.3.7",
    "npm-run-all": "^4.1.5",
    "nx": "13.10.0",
    "postcss-scss": "^4.0.3",
    "prettier": "^2.5.1",
    "react-test-renderer": "18.0.0",
    "rollup-plugin-copy": "^3.4.0",
    "scoped-css-loader": "^1.0.0",
    "stylelint": "^14.6.1",
    "stylelint-config-prettier": "^9.0.3",
    "ts-jest": "27.0.5",
    "typescript": "~4.6.2"
  }
}
